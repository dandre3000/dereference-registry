{
  "name": "@dandre3000/dereference-registry",
  "version": "0.2.0",
  "license": "MIT",
  "author": {
    "name": "DeAundre Payne",
    "email": "apps.fondling796@passinbox.com",
    "url": "https://github.com/dandre3000"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dandre3000/dereference-registry.git"
  },
  "description": "Like FinalizationRegistry but the cleanup function is guranteed to be called for each dereferenced target.",
  "keywords": [
    "memory",
    "garbage-collection",
    "FinalizationRegistry"
  ],
  "files": [
    "./build"
  ],
  "exports": {
    "types": "./build/index.d.ts",
    "import": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && bun build --entrypoints ./index.ts --outdir ./build --minify-whitespace --minify-syntax",
    "test": "node --test tests/node.test.js && bun test tests/bun.test.js && deno test -A --no-check tests/deno.test.js",
    "prepack": "bun run build && bun run test"
  },
  "engines": {
    "bun": ">=2.2.1",
    "deno": ">=1.3.1",
    "node": ">=23.5.0"
  },
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "expect": "^29.7.0",
    "typescript": "^6.0.2"
  }
}
